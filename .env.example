# ===========================================
# nas-monitor 环境变量配置
# 复制此文件为 .env 并修改对应的值
# ===========================================

# --- 日志级别 (DEBUG/INFO/WARNING/ERROR) ---
LOG_LEVEL=INFO

# --- CORS 允许的域名（逗号分隔）---
CORS_ORIGINS=http://localhost,http://localhost:3003,http://127.0.0.1

# --- JWT 认证 ---
# 生成方式: openssl rand -hex 32
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32
TOKEN_EXPIRE_MINUTES=30

# --- InfluxDB 配置 ---
INFLUXDB_USERNAME=nas_admin
INFLUXDB_PASSWORD=your_secure_password_here
INFLUXDB_TOKEN=nas_monitor_token
INFLUXDB_ORG=nas_monitor
INFLUXDB_BUCKET=nas_metrics

# --- Prometheus ---
PROMETHEUS_URL=http://localhost:9090

# --- 后端服务端口 ---
BACKEND_PORT=8017
